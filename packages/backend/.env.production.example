# Production Environment Configuration
# Copy this file to .env.production and update with actual production values

# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (Use production database credentials)
DB_HOST=your-production-db-host.com
DB_PORT=5432
DB_NAME=bounty_hunter_prod
DB_USER=bounty_hunter_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_SSL=true
DB_POOL_MIN=5
DB_POOL_MAX=50
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# Redis Configuration (Use production Redis credentials)
REDIS_HOST=your-production-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_DB=0
REDIS_MAX_RETRIES=5
REDIS_TLS=true

# JWT Configuration (MUST use strong secrets in production)
JWT_SECRET=CHANGE_THIS_TO_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=CHANGE_THIS_TO_DIFFERENT_STRONG_RANDOM_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# Admin Budget Configuration
ADMIN_MONTHLY_BUDGET=10000

# Logging Configuration
LOG_LEVEL=warn
LOG_FILE_PATH=/var/log/bounty-hunter
LOG_MAX_FILES=30
LOG_MAX_SIZE=50m
LOG_TO_CONSOLE=false

# Rate Limiting (Stricter in production)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_IP_MAX_REQUESTS=500

# CORS Configuration (Set to your frontend domain)
CORS_ORIGIN=https://your-frontend-domain.com
CORS_CREDENTIALS=true

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=CHANGE_THIS_TO_STRONG_RANDOM_SESSION_SECRET

# Performance
ENABLE_COMPRESSION=true
ENABLE_CACHE=true
CACHE_TTL=600

# Monitoring and Health Checks
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=true

# Email Configuration (if needed for notifications)
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=CHANGE_THIS_EMAIL_PASSWORD
SMTP_FROM=noreply@your-domain.com

# Application URLs
API_BASE_URL=https://api.your-domain.com
FRONTEND_URL=https://your-domain.com

# Worker Configuration
WORKER_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=5000
